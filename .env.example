# Environment variables — copy to `.env` (never commit `.env`)

NODE_ENV=development
PORT=4000
# Local long-running dev (npm run dev): use Neon DIRECT URL for both vars.
# Vercel serverless: pooled DATABASE_URL (?sslmode=require&pgbouncer=true) + direct DIRECT_URL.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Admin WhatsApp for monthly fee / enrollment contact (BD digits, e.g. 01638149875)
ADMIN_WHATSAPP_PHONE=01638149875

# Cloudinary — replace mock values with real credentials from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=mock_cloud_name
CLOUDINARY_API_KEY=mock_api_key
CLOUDINARY_API_SECRET=mock_api_secret
