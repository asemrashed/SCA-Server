generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
  SUPER_ADMIN
}

enum DeliveryMode {
  LIVE
  RECORDED
}

enum BatchStatus {
  DRAFT
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum LessonType {
  RECORDED
  LIVE
  TEXT
  DOCUMENT
}

enum EnrollmentStatus {
  PENDING
  ACTIVE
  CANCELLED
  COMPLETED
}

enum SessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum LiveClassType {
  RECURRING
  ONE_TIME
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  WRITTEN
  PDF
}

enum ExamStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum PaymentPurpose {
  ORDER
  ENROLLMENT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum MonthlyPaymentStatus {
  REQUESTED
  APPROVED
  REJECTED
}

enum ProductType {
  BOOK
  NOTES
  QUESTION_BANK
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id            String   @id @default(cuid())
  phone         String   @unique
  email         String?
  passwordHash  String
  name          String
  role          Role     @default(STUDENT)
  avatarUrl     String?
  phoneVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  refreshTokens  RefreshToken[]
  taughtBatches  BatchInstructor[]
  enrollments    Enrollment[]
  attendance     Attendance[]
  examAttempts   ExamAttempt[]
  submissions    Submission[]
  payments       Payment[]
  certificates   Certificate[]
  orders         Order[]
  monthlyPaymentsAsStudent MonthlyPayment[] @relation("MonthlyPaymentStudent")
  monthlyPaymentsReviewed  MonthlyPayment[] @relation("MonthlyPaymentReviewer")

  @@index([role])
  @@index([email])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Category {
  id         String    @id @default(cuid())
  title      String
  slug       String    @unique
  shortIntro String?
  image      String?
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  courses Course[]

  @@index([slug])
}

model Course {
  id            String       @id @default(cuid())
  title         String
  slug          String       @unique
  description   String?
  thumbnail     String?
  categoryId    String?
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  deliveryMode  DeliveryMode
  priceMinor    Int          @default(0)
  faq           Json?
  isPublished   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  modules      Module[]
  batches      Batch[]
  enrollments  Enrollment[]
  exams        Exam[]
  assignments  Assignment[]
  resources    Resource[]

  @@index([categoryId])
  @@index([deliveryMode])
}

model Subject {
  id        String   @id @default(cuid())
  batchId   String
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules   Module[]
  resources Resource[]
  questions Question[]

  @@index([batchId])
}

model Module {
  id        String   @id @default(cuid())
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lessons     Lesson[]
  exams       Exam[]
  assignments Assignment[]
  resources   Resource[]
  questions   Question[]

  @@index([courseId])
  @@index([subjectId])
}

model Lesson {
  id        String     @id @default(cuid())
  moduleId  String
  module    Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title     String
  type      LessonType @default(RECORDED)
  videoUrl  String?
  content   String?
  durationS Int?
  lectureDate DateTime? @db.Date
  order     Int        @default(0)
  isPreview Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  lessonProgress LessonProgress[]
  recordings     Recording[]
  resources      Resource[]

  @@index([moduleId])
}

model Batch {
  id                   String      @id @default(cuid())
  courseId             String
  course               Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title                String
  slug                 String      @unique
  status               BatchStatus @default(DRAFT)
  priceMinor           Int         @default(0)
  capacity             Int?
  registrationDeadline DateTime?
  startDate            DateTime?
  endDate              DateTime?
  thumbnail            String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  subjects       Subject[]
  instructors    BatchInstructor[]
  enrollments    Enrollment[]
  liveSessions        LiveSession[]
  liveClassSchedules  LiveClassSchedule[]
  recordings     Recording[]
  grantsGiven    BatchContentGrant[] @relation("GrantingBatch")
  grantsReceived BatchContentGrant[] @relation("ReceivingBatch")
  resources      Resource[]
  questions      Question[]

  @@index([courseId])
  @@index([status])
}

model BatchContentGrant {
  id               String   @id @default(cuid())
  grantingBatchId  String
  grantingBatch    Batch    @relation("GrantingBatch", fields: [grantingBatchId], references: [id], onDelete: Cascade)
  receivingBatchId String
  receivingBatch   Batch    @relation("ReceivingBatch", fields: [receivingBatchId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())

  @@unique([grantingBatchId, receivingBatchId])
  @@index([receivingBatchId])
}

model BatchInstructor {
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  instructorId String
  instructor   User     @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  assignedAt   DateTime @default(now())

  @@id([batchId, instructorId])
  @@index([instructorId])
}

model Enrollment {
  id          String           @id @default(cuid())
  studentId   String
  student     User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batchId     String?
  batch       Batch?           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  courseId    String?
  course      Course?          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  status      EnrollmentStatus @default(PENDING)
  rollNumber  String?
  progressPct Int              @default(0)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?

  lessonProgress LessonProgress[]
  payments       Payment[]
  monthlyPayments MonthlyPayment[]
  certificate    Certificate?

  @@unique([studentId, batchId])
  @@unique([studentId, courseId])
  @@index([batchId])
  @@index([courseId])
  @@index([studentId])
}

model LessonProgress {
  id           String     @id @default(cuid())
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed    Boolean    @default(false)
  completedAt  DateTime?
  updatedAt    DateTime   @updatedAt

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

enum ResourceCategory {
  GENERAL
  LECTURE_SHEET
  SOLUTION_PDF
  NOTICE
  RESULT_SHEET
  MATH_SUGGESTION
  THEORY_SUGGESTION
  EXAM
  ASSIGNMENT
}

model Resource {
  id         String           @id @default(cuid())
  title      String
  fileUrl    String
  fileType   String?
  category   ResourceCategory @default(GENERAL)
  courseId   String
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batchId    String?
  batch      Batch?           @relation(fields: [batchId], references: [id], onDelete: Cascade)
  subjectId  String?
  subject    Subject?         @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  moduleId   String?
  module     Module?          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonId   String?
  lesson     Lesson?          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  deadlineAt DateTime?
  createdAt  DateTime         @default(now())

  @@index([courseId])
  @@index([courseId, category])
  @@index([batchId])
  @@index([courseId, batchId, category])
  @@index([subjectId])
  @@index([moduleId])
  @@index([lessonId])
}

model LiveSession {
  id          String        @id @default(cuid())
  batchId     String
  batch       Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  title       String
  status      SessionStatus @default(SCHEDULED)
  joinUrl     String?
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  attendance Attendance[]
  recording  Recording?

  @@index([batchId])
  @@index([scheduledAt])
}

model LiveClassSchedule {
  id            String        @id @default(cuid())
  batchId       String
  batch         Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type          LiveClassType @default(RECURRING)
  subject       String
  daysOfWeek    Int[]         @default([])
  scheduledDate DateTime?     @db.Date
  startTime     String
  endTime       String?
  passcode      String?
  joinUrl       String
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([batchId])
  @@index([scheduledDate])
}

model Recording {
  id        String       @id @default(cuid())
  batchId   String?
  batch     Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  lessonId  String?
  lesson    Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  sessionId String?      @unique
  session   LiveSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  title     String
  videoUrl  String
  durationS Int?
  createdAt DateTime     @default(now())

  @@index([batchId])
  @@index([lessonId])
}

model Attendance {
  id        String           @id @default(cuid())
  sessionId String
  session   LiveSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status    AttendanceStatus @default(ABSENT)
  markedAt  DateTime         @default(now())

  @@unique([sessionId, studentId])
  @@index([studentId])
}

model Question {
  id        String       @id @default(cuid())
  stem      String
  type      QuestionType
  options   Json?
  correct   Json
  category  String?
  marks     Int          @default(1)
  fileUrl   String?
  batchId   String?
  batch     Batch?       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  subjectId String?
  subject   Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  moduleId  String?
  module    Module?      @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  examQuestions ExamQuestion[]

  @@index([category])
  @@index([type])
  @@index([batchId])
  @@index([subjectId])
  @@index([moduleId])
}

model Exam {
  id          String     @id @default(cuid())
  courseId    String
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      Module?    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  status      ExamStatus @default(DRAFT)
  durationMin Int?
  totalMarks  Int        @default(0)
  opensAt     DateTime?
  closesAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  questions ExamQuestion[]
  attempts  ExamAttempt[]

  @@index([courseId])
  @@index([moduleId])
}

model ExamQuestion {
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  order      Int      @default(0)
  marks      Int?

  @@id([examId, questionId])
  @@index([questionId])
}

model ExamAttempt {
  id          String        @id @default(cuid())
  examId      String
  exam        Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId   String
  student     User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status      AttemptStatus @default(IN_PROGRESS)
  answers     Json          @default("{}")
  scoreMarks  Int?
  scorePct    Int?
  startedAt   DateTime      @default(now())
  submittedAt DateTime?
  expiresAt   DateTime?

  @@unique([examId, studentId])
  @@index([studentId])
}

model Assignment {
  id          String    @id @default(cuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      Module?   @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  title       String
  description String?
  totalMarks  Int       @default(100)
  dueAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  submissions Submission[]

  @@index([courseId])
  @@index([moduleId])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileUrl      String?
  text         String?
  scoreMarks   Int?
  feedback     String?
  submittedAt  DateTime   @default(now())
  gradedAt     DateTime?

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model Product {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?
  thumbnail   String?
  type        ProductType @default(BOOK)
  priceMinor  Int         @default(0)
  stock       Int?
  isPublished Boolean     @default(false)
  digitalUrl  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  orderItems OrderItem[]

  @@index([type])
  @@index([isPublished])
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      OrderStatus @default(PENDING)
  totalMinor  Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  confirmedAt DateTime?

  items OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity       Int     @default(1)
  unitPriceMinor Int
  title          String

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose       PaymentPurpose
  enrollmentId  String?
  enrollment    Enrollment?    @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  amountMinor   Int
  discountMinor Int            @default(0)
  status        PaymentStatus  @default(PENDING)
  provider      String         @default("sslcommerz")
  providerRef   String         @unique
  transactionId String?
  couponCode    String?
  paidAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@index([enrollmentId])
  @@index([status])
}

model Certificate {
  id           String     @id @default(cuid())
  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  serial       String     @unique
  pdfUrl       String?
  issuedAt     DateTime   @default(now())

  @@index([studentId])
}

model MonthlyPayment {
  id            String               @id @default(cuid())
  enrollmentId  String
  enrollment    Enrollment           @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  studentId     String
  student       User                 @relation("MonthlyPaymentStudent", fields: [studentId], references: [id], onDelete: Cascade)
  billingMonth  String
  amountMinor   Int?
  status        MonthlyPaymentStatus @default(REQUESTED)
  note          String?
  requestedAt   DateTime             @default(now())
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    User?                @relation("MonthlyPaymentReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([enrollmentId, billingMonth])
  @@index([studentId])
  @@index([status])
  @@index([billingMonth])
}
